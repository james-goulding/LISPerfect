<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
	<UseWindowsForms>true</UseWindowsForms>
	<ApplicationIcon>LISPerfect.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="CommonLisp-Dark.xshd" />
    <None Remove="CommonLisp.xshd" />
    <None Remove="LISPerfect.ico" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="CommonLisp-Dark.xshd" />
    <EmbeddedResource Include="CommonLisp.xshd" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AvalonEdit" Version="6.3.1.120" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="LISPerfect.ico" />
  </ItemGroup>

</Project>
